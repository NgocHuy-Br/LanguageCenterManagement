<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="Language Center"
        android:supportsRtl="true"
        android:theme="@style/Theme.LanguageCenter"
        android:usesCleartextTraffic="true">

        <activity
            android:name="com.language_center.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name="com.language_center.TeacherActivity" />
        <activity android:name="com.language_center.StudentActivity" />

    </application>

</manifest>
